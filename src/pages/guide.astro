---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getAllProjects, generateSlug, formatStars } from "../lib/directory";
import scenarioData from "../data/scenarios.json";

const projects = getAllProjects();

// Short labels for the sticky pill nav
const pillLabels: Record<string, string> = {
  "solo-dev-getting-started": "Getting started",
  "level-up-existing-agent": "Level up",
  "building-product-with-agents": "Building a product",
  "parallel-agents": "Parallel agents",
  "autonomous-operations": "Autonomous ops",
  "non-technical-user": "Non-developer",
};

const scenarios = scenarioData.scenarios.map((scenario) => ({
  ...scenario,
  pillLabel: pillLabels[scenario.id] || scenario.title.substring(0, 25),
  tools: scenario.tools
    .sort((a, b) => a.order - b.order)
    .map((tool) => {
      const project = projects.find((p) => p.name === tool.name);
      return { ...tool, project };
    })
    .filter((tool) => tool.project),
}));
---

<BaseLayout
  title="Find Your Tool"
  description="Answer one question — what's your situation? — and get curated, opinionated recommendations for which AI agent tools to use."
>
  <!-- Hero -->
  <section class="border-b border-white/10">
    <div class="mx-auto max-w-[1400px] px-6 py-20">
      <div class="mb-6">
        <span class="status-pill">Curated &middot; {projects.length} tools</span>
      </div>
      <h1>Find your tool</h1>
      <p class="mt-8 max-w-2xl text-lg text-white/70">
        The directory has {projects.length} tools. You don't need to browse them all. Pick the scenario that matches your situation and get an opinionated, curated starting point.
      </p>
    </div>
  </section>

  <!-- Scenario Navigation (full cards) -->
  <section class="border-b border-black/10 dark:border-white/10">
    <div class="mx-auto max-w-5xl px-6 py-8">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {scenarios.map((scenario) => (
          <a
            href={`#${scenario.id}`}
            class="group flex items-start gap-3 rounded-xl border border-black/10 bg-white px-4 py-3 no-underline transition-all hover:border-black/25 hover:shadow-sm dark:border-white/10 dark:bg-neutral-900 dark:hover:border-white/20"
          >
            <div class="flex-1 min-w-0">
              <span class="block text-sm font-medium text-neutral-900 dark:text-white leading-snug">{scenario.title}</span>
              <span class="mt-1 block text-xs text-neutral-500 dark:text-neutral-400 line-clamp-2 leading-relaxed">{scenario.description}</span>
              <div class="mt-2 flex items-center gap-2">
                <span class="inline-block rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400">{scenario.tools.length} tools</span>
              </div>
            </div>
            <svg class="mt-1 h-4 w-4 shrink-0 text-neutral-400 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sticky compact nav (pills) -->
  <nav class="sticky top-[69px] z-30 border-b border-black/10 bg-white/95 backdrop-blur-sm dark:border-white/10 dark:bg-neutral-950/95">
    <div class="mx-auto flex max-w-5xl gap-2 overflow-x-auto px-6 py-2.5 scrollbar-hide">
      {scenarios.map((scenario) => (
        <a
          href={`#${scenario.id}`}
          class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-black/10 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:border-white/10 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-white"
        >
          {scenario.pillLabel}
        </a>
      ))}
    </div>
  </nav>

  <!-- Scenario Sections -->
  {scenarios.map((scenario) => (
    <section id={scenario.id} class="border-b border-black/10 dark:border-white/10 scroll-mt-[120px]">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-2xl font-semibold">{scenario.title}</h2>
        <p class="mt-3 max-w-2xl text-neutral-500 dark:text-neutral-400">
          {scenario.description}
        </p>
        <p class="mt-2 text-xs text-neutral-400 dark:text-neutral-500">
          Ranked by our recommendation for this use case. #1 is where we'd start.
        </p>

        <div class="mt-8 space-y-4">
          {scenario.tools.map((tool, idx) => (
            idx === 0 ? (
              <!-- #1 Recommendation: prominent card -->
              <div class="rounded-xl border border-black/15 bg-white p-6 dark:border-white/15 dark:bg-neutral-900">
                <div class="flex gap-5">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-sm font-bold text-white dark:bg-white dark:text-black">
                    1
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                      <a
                        href={`/project/${generateSlug(tool.name)}`}
                        class="text-lg font-semibold text-neutral-900 no-underline hover:underline dark:text-white"
                      >
                        {tool.name} <span class="inline-block text-neutral-400 transition-transform group-hover:translate-x-0.5">&rarr;</span>
                      </a>
                      {tool.project?.github_stars && (
                        <span class="inline-flex items-center gap-1 text-xs text-neutral-400 dark:text-neutral-500">
                          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
                          {formatStars(tool.project.github_stars)}
                        </span>
                      )}
                    </div>
                    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                      {tool.role}
                    </p>
                    {tool.project?.full_description && (
                      <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-500 leading-relaxed line-clamp-2">
                        {tool.project.full_description}
                      </p>
                    )}
                    <div class="mt-4 flex flex-wrap items-center gap-3">
                      {tool.project?.difficulty && (
                        <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                          tool.project.difficulty === 'beginner' ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-500' :
                          tool.project.difficulty === 'intermediate' ? 'bg-amber-50 text-amber-700 dark:bg-amber-950 dark:text-amber-500' :
                          'bg-rose-50 text-rose-700 dark:bg-rose-950 dark:text-rose-500'
                        }`}>
                          {tool.project.difficulty === 'beginner' ? 'Beginner' : tool.project.difficulty === 'intermediate' ? 'Intermediate' : 'Advanced'}
                        </span>
                      )}
                      {tool.project?.features.includes("Open Source") && (
                        <span class="inline-block rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">Open Source</span>
                      )}
                      {tool.project?.features.includes("Model-Agnostic") && (
                        <span class="inline-block rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">Model-Agnostic</span>
                      )}
                      <a
                        href={`/project/${generateSlug(tool.name)}`}
                        class="ml-auto text-sm font-medium text-neutral-900 no-underline hover:underline dark:text-white"
                      >
                        View project &rarr;
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <!-- #2+ tools: compact list -->
              <div class="flex gap-5">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-sm font-semibold text-white dark:bg-white dark:text-black">
                  {idx + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <a
                      href={`/project/${generateSlug(tool.name)}`}
                      class="text-lg font-semibold text-neutral-900 no-underline hover:underline dark:text-white"
                    >
                      {tool.name} <span class="text-neutral-400">&rarr;</span>
                    </a>
                    {tool.project?.github_stars && (
                      <span class="inline-flex items-center gap-1 text-xs text-neutral-400 dark:text-neutral-500">
                        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
                        {formatStars(tool.project.github_stars)}
                      </span>
                    )}
                  </div>
                  <p class="mt-1.5 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                    {tool.role}
                  </p>
                  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-neutral-400">
                    {tool.project?.difficulty && (
                      <span class={`inline-block rounded-full px-2 py-0.5 font-medium ${
                        tool.project.difficulty === 'beginner' ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-500' :
                        tool.project.difficulty === 'intermediate' ? 'bg-amber-50 text-amber-700 dark:bg-amber-950 dark:text-amber-500' :
                        'bg-rose-50 text-rose-700 dark:bg-rose-950 dark:text-rose-500'
                      }`}>
                        {tool.project.difficulty === 'beginner' ? 'Beginner' : tool.project.difficulty === 'intermediate' ? 'Intermediate' : 'Advanced'}
                      </span>
                    )}
                    {tool.project?.features.includes("Open Source") && (
                      <span class="inline-block rounded-full bg-neutral-100 px-2 py-0.5 font-medium text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">Open Source</span>
                    )}
                    {tool.project?.features.includes("Model-Agnostic") && (
                      <span class="inline-block rounded-full bg-neutral-100 px-2 py-0.5 font-medium text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">Model-Agnostic</span>
                    )}
                    <a
                      href={`/project/${generateSlug(tool.name)}`}
                      class="ml-auto text-sm font-medium text-neutral-900 no-underline hover:underline dark:text-white"
                    >
                      View project &rarr;
                    </a>
                  </div>
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="border-b border-black/10 dark:border-white/10">
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <h2 class="text-2xl font-semibold">None of these fit?</h2>
      <p class="mx-auto mt-4 max-w-xl text-neutral-500 dark:text-neutral-400">
        Browse the full directory with filters for type, role, use case, difficulty, and features.
      </p>
      <div class="mt-8">
        <a href="/directory" class="btn-primary">Browse the directory</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
