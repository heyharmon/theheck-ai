---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TypeBadge from "../../components/TypeBadge.astro";
import FeatureBadge from "../../components/FeatureBadge.astro";
import StarCount from "../../components/StarCount.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import {
  getAllProjects,
  generateSlug,
  getProjectsByType,
  getTypeLabel,
  getDifficultyLabel,
  getDifficultyColor,
  getRelatedTools,
  getToolsThatExtend,
  getEcosystemFor,
  type Project,
} from "../../lib/directory";
import {
  getResourcesForTool,
  getResourceTypeLabel,
  getResourceTypeBadgeClass,
} from "../../lib/resources";

export async function getStaticPaths() {
  const projects = getAllProjects();
  return projects.map((project) => ({
    params: { slug: generateSlug(project.name) },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };

// Relationship-aware related tools
const relationshipSections = getRelatedTools(project);
const extendedBy = getToolsThatExtend(project);
const ecosystemSiblings = getEcosystemFor(project);

// Deduplicate: collect all tool names shown in relationship sections
const shownNames = new Set<string>();
relationshipSections.forEach(s => s.tools.forEach(t => shownNames.add(t.name)));
extendedBy.forEach(t => shownNames.add(t.name));
ecosystemSiblings.forEach(t => shownNames.add(t.name));

// Fallback: if no relationships, show same-type tools (current behavior)
const hasRelationships = relationshipSections.length > 0 || extendedBy.length > 0 || ecosystemSiblings.length > 0;
const fallbackRelated = hasRelationships
  ? []
  : getProjectsByType(project.type)
      .filter((p) => p.name !== project.name)
      .slice(0, 3);

const relatedResources = getResourcesForTool(project.name);

const diffLabel = getDifficultyLabel(project.difficulty);
const diffColor = getDifficultyColor(project.difficulty);
const diffBadgeBg: Record<string, string> = {
  emerald: "bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-500",
  amber: "bg-amber-50 text-amber-700 dark:bg-amber-950 dark:text-amber-500",
  rose: "bg-rose-50 text-rose-700 dark:bg-rose-950 dark:text-rose-500",
  neutral: "bg-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300",
};

const diffExplanation: Record<string, string> = {
  beginner: "No coding required",
  intermediate: "Some development experience needed",
  advanced: "For experienced developers",
};
---

<BaseLayout title={project.name} description={project.full_description.slice(0, 160)}>
  <!-- Header -->
  <section class="border-b border-black/10 bg-neutral-50 dark:border-white/10 dark:bg-neutral-900">
    <div class="mx-auto max-w-5xl px-6 py-12">
      <a href="/directory" class="inline-flex items-center gap-1 text-sm text-neutral-500 no-underline hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
        </svg>
        Back to Directory
      </a>

      <div class="mt-6 flex flex-wrap items-start justify-between gap-6">
        <div class="flex-1 min-w-0">
          <h1 class="text-4xl sm:text-5xl">{project.name}</h1>
          <p class="mt-2 text-lg text-neutral-500">by {project.creator}</p>

          {/* Best for line */}
          {project.use_cases.length > 0 && (
            <p class="mt-3 text-sm text-neutral-500 dark:text-neutral-400">
              <span class="font-medium text-neutral-700 dark:text-neutral-300">Best for:</span>{" "}
              {project.use_cases.join(", ")}
            </p>
          )}

          {/* Feature attribute pills — high-signal badges right in the header */}
          {project.features.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {project.features.map((f) => (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-neutral-900 px-3 py-1 text-xs font-medium text-white dark:bg-white dark:text-black">
                  <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  {f}
                </span>
              ))}
            </div>
          )}

          <dl class="mt-5 grid grid-cols-[auto_1fr] gap-x-4 gap-y-3 text-sm">
            <dt class="text-neutral-400">Type</dt>
            <dd class="flex flex-wrap items-center gap-2">
              <span class="inline-block rounded-full bg-neutral-900 px-3 py-1 text-xs font-medium text-white dark:bg-white dark:text-black">
                {getTypeLabel(project.type)}
              </span>
            </dd>
            {project.difficulty && (
              <>
                <dt class="text-neutral-400">Difficulty</dt>
                <dd class="flex items-center gap-2">
                  <span class={`inline-block rounded-full px-3 py-1 text-xs font-medium ${diffBadgeBg[diffColor] || diffBadgeBg.neutral}`}>
                    {diffLabel}
                  </span>
                  <span class="text-xs text-neutral-400 dark:text-neutral-500">
                    {diffExplanation[project.difficulty] || ""}
                  </span>
                </dd>
              </>
            )}
            {project.tag && (
              <>
                <dt class="text-neutral-400">Tag</dt>
                <dd>
                  <span class="inline-block rounded-full border border-dashed border-neutral-300 px-2.5 py-0.5 text-xs font-medium text-neutral-500 dark:border-neutral-600 dark:text-neutral-400">
                    #{project.tag}
                  </span>
                </dd>
              </>
            )}
            {project.github_stars && (
              <>
                <dt class="text-neutral-400">Stars</dt>
                <dd><StarCount stars={project.github_stars} /></dd>
              </>
            )}
          </dl>
        </div>

        {/* Get Started actions — prominent right column */}
        <div class="flex flex-col gap-3 sm:items-end shrink-0">
          {project.website_url && (
            <a
              href={project.website_url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary inline-flex items-center gap-2"
            >
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.182a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V6.56l-5.22 5.22a.75.75 0 11-1.06-1.06l5.22-5.22h-2.44a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
              </svg>
              Visit Website
            </a>
          )}
          {project.github_url && (
            <a
              href={project.github_url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost inline-flex items-center gap-2"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>
          )}
          {project.github_url && (
            <div class="mt-1 rounded-lg border border-black/10 bg-white px-3 py-2 dark:border-white/10 dark:bg-neutral-800">
              <p class="text-[11px] font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-500">Clone</p>
              <code class="block mt-0.5 text-xs font-mono text-neutral-600 dark:text-neutral-300 select-all">
                git clone {project.github_url}.git
              </code>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="border-b border-black/10 dark:border-white/10">
    <div class="mx-auto max-w-5xl px-6 py-10">
      <h2 class="text-xl font-semibold">About</h2>
      <p class="mt-4 text-lg leading-relaxed">{project.full_description}</p>
    </div>
  </section>

  <!-- Why Discussed -->
  {project.why_discussed && (
    <section class="border-b border-black/10 bg-neutral-50 dark:border-white/10 dark:bg-neutral-900">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold">Why people are talking about it</h2>
        <blockquote class="mt-4 border-l-4 border-black/20 pl-6 text-lg italic text-neutral-700 dark:border-white/20 dark:text-neutral-300">
          {project.why_discussed}
        </blockquote>
      </div>
    </section>
  )}

  <!-- Key Features — 2-column grid -->
  {project.key_features.length > 0 && (
    <section class="border-b border-black/10 dark:border-white/10">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold">Key Features</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {project.key_features.map((feature) => (
            <div class="flex items-start gap-3 rounded-lg border border-black/10 bg-white px-4 py-3 dark:border-white/10 dark:bg-neutral-900">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-neutral-400 dark:text-neutral-500" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-neutral-700 dark:text-neutral-300">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Notes -->
  {project.notes && (
    <section class="border-b border-black/10 bg-neutral-50 dark:border-white/10 dark:bg-neutral-900">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold">Notes</h2>
        <p class="mt-4">{project.notes}</p>
      </div>
    </section>
  )}

  <!-- Related Reading -->
  {relatedResources.length > 0 && (
    <section class="border-b border-black/10 bg-neutral-50 dark:border-white/10 dark:bg-neutral-900">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold">Related Reading</h2>
        <p class="mt-2 text-sm text-neutral-500">Curated articles and guides that feature {project.name}.</p>
        <ul class="mt-6 space-y-4">
          {relatedResources.map((resource) => (
            <li class="rounded-xl border border-black/10 bg-white p-5 dark:border-white/10 dark:bg-neutral-900">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <a
                    href={resource.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-display font-medium text-neutral-900 no-underline hover:text-neutral-600 hover:underline transition-colors dark:text-white dark:hover:text-neutral-300"
                  >
                    {resource.name}
                  </a>
                  <p class="mt-1.5 text-sm text-neutral-500 leading-relaxed">{resource.description}</p>
                  <p class="mt-2 text-xs text-neutral-400">by {resource.author}</p>
                </div>
                <span class={`shrink-0 ${getResourceTypeBadgeClass(resource.type)}`}>
                  {getResourceTypeLabel(resource.type)}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Relationship Sections -->
  {extendedBy.length > 0 && (
    <section class="border-b border-black/10 dark:border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <h2 class="text-xl font-semibold">Enhanced by</h2>
        <p class="mt-2 text-sm text-neutral-500">Tools that extend or add capabilities to {project.name}.</p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {extendedBy.map((p) => (
            <ProjectCard project={p} slug={generateSlug(p.name)} />
          ))}
        </div>
      </div>
    </section>
  )}

  {relationshipSections.map((section) => (
    <section class="border-b border-black/10 dark:border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <h2 class="text-xl font-semibold">{section.label}</h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {section.tools.map((p) => (
            <ProjectCard project={p} slug={generateSlug(p.name)} />
          ))}
        </div>
      </div>
    </section>
  ))}

  {ecosystemSiblings.length > 0 && (
    <section class="border-b border-black/10 dark:border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <h2 class="text-xl font-semibold">Same ecosystem</h2>
        <p class="mt-2 text-sm text-neutral-500">Other tools in the {project.relationships?.ecosystem} ecosystem.</p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {ecosystemSiblings.map((p) => (
            <ProjectCard project={p} slug={generateSlug(p.name)} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Fallback: More of same type (only when no relationships exist) -->
  {fallbackRelated.length > 0 && (
    <section class="border-b border-black/10 dark:border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <h2 class="text-xl font-semibold">More {project.type === "agent-tool" ? "Agents" : project.type === "multi-agent-platform" ? "Multi-Agent Platforms" : "Developer Utilities"}</h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {fallbackRelated.map((p) => (
            <ProjectCard project={p} slug={generateSlug(p.name)} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
