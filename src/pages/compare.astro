---
import BaseLayout from "../layouts/BaseLayout.astro";
import ComparisonTable from "../components/ComparisonTable.vue";
import { getAllProjects, getMetadata } from "../lib/directory";

const projects = getAllProjects();
const metadata = getMetadata();
---

<BaseLayout title="Compare" description="Select 2-4 agent tools and compare them side by side — features, difficulty, use cases, and more.">
  <section class="border-b border-black/10 bg-neutral-50 dark:border-white/10 dark:bg-neutral-900">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h1>Compare Tools</h1>
      <p class="mt-4 max-w-2xl text-lg text-neutral-500">
        {metadata.total_entries} tools. Select 2&ndash;4 from the table and compare them side by side.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-6 py-12">
      <ComparisonTable client:visible projects={projects} />
    </div>
  </section>
</BaseLayout>
