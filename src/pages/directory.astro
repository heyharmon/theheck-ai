---
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectoryBrowser from "../components/DirectoryBrowser.vue";
import { getAllProjects, getTypes, getUseCases, getDifficultyLevels, getMetadata, getFeatures } from "../lib/directory";

const projects = getAllProjects();
const types = getTypes();
const useCases = getUseCases();
const difficultyLevels = getDifficultyLevels();
const metadata = getMetadata();
const features = getFeatures();
---

<BaseLayout title="Directory" description="Browse and filter all agent tools, multi-agent platforms, and developer utilities.">
  <section class="border-b border-white/10">
    <div class="mx-auto max-w-[1400px] px-6 py-20">
      <div class="mb-6">
        <span class="status-pill">{metadata.total_entries} tools &middot; {metadata.use_cases.length} use cases</span>
      </div>
      <h1>Directory</h1>
      <p class="mt-8 max-w-2xl text-lg text-white/70">
        {metadata.total_entries} tools tracked and updated — last reviewed {metadata.last_updated}. Filter by type, difficulty, and use case.
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-[0.1em] text-white/50">
        <span>{metadata.total_entries} tools</span>
        <span class="text-white/20">&middot;</span>
        <span>{metadata.types.length} types</span>
        <span class="text-white/20">&middot;</span>
        <span>{metadata.use_cases.length} use cases</span>
        <span class="text-white/20">&middot;</span>
        <span>{metadata.difficulty_levels.length} difficulty levels</span>
        <span class="text-white/20">&middot;</span>
        <a href="/guide" class="normal-case tracking-normal">Not sure where to start?</a>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-6 py-12">
      <DirectoryBrowser
        client:load
        projects={projects}
        types={types}
        useCases={useCases}
        difficultyLevels={difficultyLevels}
        features={features}
      />
    </div>
  </section>
</BaseLayout>
