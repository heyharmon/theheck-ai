---
import nav from "../data/nav.json";
import siteMeta from "../data/site-meta.json";

const pathname = Astro.url.pathname;
const sortedNav = [...nav].sort((a, b) => a.order - b.order);
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-neutral-950/90 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-4">
    <a
      href="/"
      class="font-display text-base font-black tracking-tight text-white no-underline"
      style="letter-spacing: -0.04em;"
    >
      {siteMeta.name}
    </a>

    <div class="flex items-center gap-6">
      <ul class="flex items-center gap-6">
        {
          sortedNav.map((item) => {
            const isActive =
              item.href === "/"
                ? pathname === "/"
                : pathname.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "font-mono text-[11px] font-bold uppercase tracking-[0.15em] no-underline transition-colors",
                    isActive
                      ? "text-[#EBFF00]"
                      : "text-white/60 hover:text-[#EBFF00]",
                  ]}
                  style={isActive ? "text-decoration: underline; text-decoration-color: #EBFF00; text-underline-offset: 6px;" : ""}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </nav>
</header>
