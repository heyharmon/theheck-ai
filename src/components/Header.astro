---
import nav from "../data/nav.json";
import siteMeta from "../data/site-meta.json";
import DarkModeToggle from "./DarkModeToggle.astro";

const pathname = Astro.url.pathname;
const sortedNav = [...nav].sort((a, b) => a.order - b.order);
---

<header class="border-b border-black/10 bg-white dark:border-white/10 dark:bg-neutral-950">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-semibold tracking-tight text-black no-underline dark:text-white">
      {siteMeta.name}
    </a>

    <div class="flex items-center gap-6">
      <ul class="flex items-center gap-6">
        {
          sortedNav.map((item) => {
            const isActive =
              item.href === "/"
                ? pathname === "/"
                : pathname.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "text-sm font-medium no-underline transition-colors",
                    isActive
                      ? "text-black dark:text-white"
                      : "text-neutral-500 hover:text-black dark:text-neutral-400 dark:hover:text-white",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <DarkModeToggle />
    </div>
  </nav>
</header>
