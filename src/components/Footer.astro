---
import siteMeta from "../data/site-meta.json";
import footerData from "../data/footer.json";

const socialLinks = Object.entries(siteMeta.social).filter(([_, url]) => url);
const navSection = footerData.find((s) => s.section === "Navigation");
---

<footer class="border-t border-white/10 bg-neutral-950 py-16">
  <div class="mx-auto max-w-[1400px] px-6">
    <div class="flex flex-col items-center gap-6 text-center">
      <a
        href="/"
        class="font-display text-lg font-black tracking-tight text-white no-underline"
        style="letter-spacing: -0.04em;"
      >
        {siteMeta.name}
      </a>

      {siteMeta.tagline && (
        <p class="font-mono text-xs uppercase tracking-[0.1em] text-white/50">{siteMeta.tagline}</p>
      )}

      {navSection && navSection.links.length > 0 && (
        <nav>
          <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            {navSection.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-white/60 no-underline transition-colors hover:text-[#EBFF00]"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {socialLinks.length > 0 && (
        <div class="flex items-center justify-center gap-6">
          {socialLinks.map(([platform, url]) => (
            <a
              href={url as string}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-white/60 no-underline transition-colors hover:text-[#EBFF00]"
            >
              {platform}
            </a>
          ))}
        </div>
      )}

      <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-white/40">{siteMeta.copyright}</p>
    </div>
  </div>
</footer>
