---
import siteMeta from "../data/site-meta.json";
import footerData from "../data/footer.json";

const socialLinks = Object.entries(siteMeta.social).filter(([_, url]) => url);
const navSection = footerData.find((s) => s.section === "Navigation");
---

<footer class="border-t border-black/10 bg-white py-16 dark:border-white/10 dark:bg-neutral-950">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col items-center gap-6 text-center">
      <a href="/" class="text-xl font-semibold tracking-tight text-neutral-900 no-underline dark:text-white">
        {siteMeta.name}
      </a>

      {siteMeta.tagline && (
        <p class="text-sm text-neutral-500 dark:text-neutral-400">{siteMeta.tagline}</p>
      )}

      {navSection && navSection.links.length > 0 && (
        <nav>
          <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            {navSection.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-neutral-500 no-underline transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {socialLinks.length > 0 && (
        <div class="flex items-center justify-center gap-6">
          {socialLinks.map(([platform, url]) => (
            <a
              href={url as string}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm capitalize text-neutral-500 no-underline transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white"
            >
              {platform}
            </a>
          ))}
        </div>
      )}

      <p class="text-xs text-neutral-400 dark:text-neutral-500">{siteMeta.copyright}</p>
    </div>
  </div>
</footer>
