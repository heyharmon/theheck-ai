---
import siteMeta from "../data/site-meta.json";

const socialLinks = Object.entries(siteMeta.social).filter(([_, url]) => url);
---

<footer class="border-t border-neutral-200 bg-neutral-50 py-16">
  <div class="mx-auto max-w-5xl px-6 text-center">
    <a href="/" class="text-xl font-semibold tracking-tight text-neutral-900 no-underline">
      {siteMeta.name}
    </a>

    {siteMeta.tagline && (
      <p class="mt-2 text-sm text-neutral-500">{siteMeta.tagline}</p>
    )}

    {socialLinks.length > 0 && (
      <div class="mt-6 flex items-center justify-center gap-6">
        {socialLinks.map(([platform, url]) => (
          <a
            href={url as string}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm capitalize text-neutral-500 no-underline transition-colors hover:text-neutral-900"
          >
            {platform}
          </a>
        ))}
      </div>
    )}

    <p class="mt-8 text-xs text-neutral-400">{siteMeta.copyright}</p>
  </div>
</footer>
