---
import { getTypeColor } from "../lib/directory";

interface Props {
  name: string;
  typeSlug: string;
  count: number;
  description: string;
  href: string;
}

const { name, typeSlug, count, description, href } = Astro.props;
---

<a
  href={href}
  class="card-interactive block border-t-2 border-t-black no-underline dark:border-t-white"
>
  <h3 class="text-lg font-semibold text-black dark:text-white">
    {name}
  </h3>
  <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">{description}</p>
  <p class="mt-3 text-sm font-medium text-neutral-700 dark:text-neutral-300">
    {count} {count === 1 ? "project" : "projects"}
  </p>
</a>
