---
interface Props {
  name: string;
  typeSlug: string;
  count: number;
  description: string;
  href: string;
}

const { name, count, description, href } = Astro.props;
---

<a
  href={href}
  class="card-interactive group block border-t-2 border-t-white/40 no-underline transition-colors hover:border-t-[#EBFF00]"
>
  <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-white/40">Type</p>
  <h3 class="mt-1 font-display text-xl font-bold text-white" style="letter-spacing: -0.02em;">
    {name}
  </h3>
  <p class="mt-3 text-sm text-white/70 leading-relaxed">{description}</p>
  <p class="mt-4 font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-[#EBFF00]">
    {count} {count === 1 ? "project" : "projects"} &rarr;
  </p>
</a>
