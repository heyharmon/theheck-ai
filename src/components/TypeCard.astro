---
import { getTypeColor } from "../lib/directory";

interface Props {
  name: string;
  typeSlug: string;
  count: number;
  description: string;
  href: string;
}

const { name, typeSlug, count, description, href } = Astro.props;
const color = getTypeColor(typeSlug);

const borderColors: Record<string, string> = {
  indigo: "border-indigo-500",
  emerald: "border-emerald-500",
  amber: "border-amber-500",
  neutral: "border-neutral-500",
};

const textColors: Record<string, string> = {
  indigo: "text-indigo-600",
  emerald: "text-emerald-600",
  amber: "text-amber-600",
  neutral: "text-neutral-600",
};
---

<a
  href={href}
  class={`card-interactive block border-t-4 no-underline ${borderColors[color]}`}
>
  <h3 class={`text-lg font-semibold ${textColors[color]}`}>
    {name}
  </h3>
  <p class="mt-2 text-sm text-neutral-500">{description}</p>
  <p class="mt-3 text-sm font-medium text-neutral-700">
    {count} {count === 1 ? "project" : "projects"}
  </p>
</a>
