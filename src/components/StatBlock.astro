---
interface Props {
  value: string | number;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center">
  <div class="font-display text-5xl text-white sm:text-6xl" style="font-weight: 900; letter-spacing: -0.04em; line-height: 0.9;">{value}</div>
  <div class="mt-3 font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-white/50">{label}</div>
</div>
