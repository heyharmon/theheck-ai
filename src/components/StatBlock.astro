---
interface Props {
  value: string | number;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center">
  <div class="text-4xl font-bold tracking-tight text-white">{value}</div>
  <div class="mt-1 text-sm font-medium uppercase tracking-wider text-neutral-400">{label}</div>
</div>
