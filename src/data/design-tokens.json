{
  "meta": {
    "version": "2.0",
    "description": "Machine-readable design system. Monochromatic black/white/gray palette inspired by ui.sh. Agents read this as the source of truth for where and how to use design tokens."
  },
  "colors": {
    "background": {
      "primary": "white",
      "secondary": "neutral-50",
      "tertiary": "neutral-100",
      "card": "white"
    },
    "text": {
      "primary": "black",
      "body": "neutral-600",
      "muted": "neutral-500",
      "subtle": "neutral-400",
      "accent": "black"
    },
    "border": {
      "default": "black/10",
      "card": "black/10",
      "input": "neutral-300",
      "focus": "black"
    },
    "accent": {
      "base": "black",
      "hover": "neutral-800",
      "light": "neutral-50",
      "note": "Monochromatic system — no colored accent. Use black/white/gray only."
    },
    "button": {
      "primary": {
        "bg": "black",
        "text": "white",
        "hoverBg": "neutral-800"
      },
      "ghost": {
        "bg": "transparent",
        "text": "black",
        "border": "black/20",
        "hoverBg": "black",
        "hoverText": "white",
        "hoverBorder": "black"
      }
    }
  },
  "typography": {
    "fonts": {
      "heading": "Inter",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "headings": {
      "h1": {
        "classes": "font-display font-medium tracking-tight text-black",
        "lineHeight": "1.08",
        "sizing": "clamp(2.25rem, 5vw, 3.5rem)",
        "letterSpacing": "-0.04em"
      },
      "h2": {
        "classes": "font-display font-semibold tracking-tight text-black",
        "lineHeight": "1.15",
        "sizing": "clamp(1.5rem, 3vw, 2rem)",
        "letterSpacing": "-0.025em"
      },
      "h3": {
        "classes": "font-display font-medium text-black text-lg",
        "lineHeight": "1.25"
      }
    },
    "body": {
      "classes": "text-neutral-600",
      "lineHeight": "1.7"
    },
    "small": {
      "classes": "text-sm text-neutral-400"
    },
    "label": {
      "classes": "text-sm font-medium uppercase tracking-wider text-neutral-500"
    }
  },
  "spacing": {
    "sectionPadding": "py-24 sm:py-32",
    "containerMax": "max-w-5xl",
    "containerPx": "px-6",
    "gridGap": "gap-8",
    "cardPadding": "p-8"
  },
  "effects": {
    "borderRadius": {
      "card": "rounded-xl",
      "button": "rounded-xl",
      "input": "rounded-lg",
      "small": "rounded"
    },
    "shadows": {
      "subtle": "shadow-sm",
      "note": "Use sparingly — prefer flat borders (black/10) for most components"
    }
  },
  "componentPatterns": {
    "hero-text": {
      "description": "Text-only hero with headline, subheadline, and dual CTA buttons (primary + ghost). White background. Large headline with tight tracking.",
      "reference": "index.astro hero section"
    },
    "card-grid": {
      "description": "Grid of bordered cards (rounded-xl, border-black/10, p-8) with icon, title, and description. 3-column on lg, 2-column on sm.",
      "reference": "index.astro features section, services.astro cards"
    },
    "cta-centered": {
      "description": "Centered text section with heading, description, and primary button. neutral-50 or white background.",
      "reference": "index.astro CTA section"
    },
    "section-2col": {
      "description": "Two-column grid — one side text content with ghost button, other side image (aspect-4/3, rounded-xl).",
      "reference": "index.astro about section, about.astro content"
    },
    "section-alternating-bg": {
      "description": "Sections alternate between bg-white and bg-neutral-50, separated by border-t border-black/10.",
      "reference": "All page sections"
    }
  }
}
